{
  "name": "taskpro-backend",
  "private": true,
  "type": "module",
  "engines": {
    "node": ">=22.0.0"
  },
  "scripts": {
    "start": "node dist/server.cjs",
    "build": "tsup app/server.ts",
    "dev": "tsx watch --include ./openapi.json app/server.ts",
    "lint": "eslint --fix app/**/*.ts",
    "format": "prettier --write ./app",
    "format:check": "prettier --check ./app",
    "prepare": "husky"
  },
  "prisma": {
    "schema": "./prisma"
  },
  "dependencies": {
    "@better-auth/passkey": "^1.6.23",
    "@better-auth/redis-storage": "^1.6.23",
    "@hono/node-server": "^2.0.11",
    "@hono/swagger-ui": "^0.6.1",
    "@hono/zod-validator": "^0.9.0",
    "@prisma/client": "^6.19.3",
    "better-auth": "^1.6.23",
    "cloudinary": "^2.10.0",
    "hono": "^4.12.31",
    "ioredis": "^5.11.1",
    "resend": "^6.17.2",
    "ua-parser-js": "^2.0.10",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@commitlint/cli": "^21.2.1",
    "@commitlint/config-conventional": "^21.2.0",
    "@eslint/js": "^10.0.1",
    "@ianvs/prettier-plugin-sort-imports": "^4.7.1",
    "@types/node": "^25.9.5",
    "eslint": "^10.7.0",
    "eslint-formatter-mo": "^2.4.1",
    "globals": "^17.7.0",
    "husky": "^9.1.7",
    "jiti": "^2.7.0",
    "lint-staged": "^17.0.8",
    "prettier": "^3.9.5",
    "prisma": "^6.19.3",
    "tsup": "^8.5.1",
    "tsx": "^4.23.0",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.63.0"
  }
}
