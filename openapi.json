{
  "openapi": "3.1.0",
  "info": {
    "version": "2.3.0",
    "title": "Task Pro API",
    "description": "Task Pro API provides endpoints for managing projects, tasks, and user assignments with secure authentication and efficient workflows.",
    "contact": {
      "name": "TaskPro",
      "url": "https://www.taskpro.qzz.io"
    }
  },
  "servers": [
    { "url": "http://localhost:9537/api" },
    { "url": "https://api.taskpro.qzz.io" }
  ],
  "paths": {
    "/user/help": {
      "post": {
        "tags": ["User"],
        "operationId": "help",
        "summary": "Send email need help",
        "security": [{ "bearerAuth": [] }],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "required": ["email", "comment"],
                "properties": {
                  "email": {
                    "type": "string",
                    "format": "email",
                    "example": "user@example.com"
                  },
                  "comment": {
                    "type": "string",
                    "example": "Need help with the Kanban board feature."
                  }
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "message": {
                      "type": "string",
                      "example": "Email sent"
                    }
                  }
                }
              }
            }
          },
          "400": { "$ref": "#/components/responses/BadRequestError" },
          "401": { "$ref": "#/components/responses/Unauthorized" }
        }
      }
    },
    "/user/settings": {
      "get": {
        "tags": ["User"],
        "operationId": "getAllSettings",
        "summary": "Get all user settings",
        "security": [{ "bearerAuth": [] }],
        "responses": {
          "200": { "$ref": "#/components/responses/GetAllSettingsResponse" },
          "401": { "$ref": "#/components/responses/Unauthorized" }
        }
      }
    },
    "/user/settings/general": {
      "patch": {
        "tags": ["User"],
        "operationId": "updateGeneralSettings",
        "summary": "Update general settings",
        "security": [{ "bearerAuth": [] }],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "required": [
                  "firstDayOfWeek",
                  "boardBackgroundBlur",
                  "usePointerCursors"
                ],
                "properties": {
                  "firstDayOfWeek": {
                    "type": "string",
                    "example": "monday"
                  },
                  "boardBackgroundBlur": {
                    "type": "string",
                    "example": "off"
                  },
                  "usePointerCursors": {
                    "type": "boolean",
                    "example": true
                  }
                }
              }
            }
          }
        },
        "responses": {
          "200": { "$ref": "#/components/responses/GeneralSettingsResponse" },
          "401": { "$ref": "#/components/responses/Unauthorized" }
        }
      }
    },
    "/user/settings/task": {
      "patch": {
        "tags": ["User"],
        "operationId": "updateTaskSettings",
        "summary": "Update task settings",
        "security": [{ "bearerAuth": [] }],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "required": [
                  "cardDensity",
                  "sortTasksBy",
                  "showCompletedTasks"
                ],
                "properties": {
                  "cardDensity": {
                    "type": "string",
                    "example": "compact"
                  },
                  "sortTasksBy": {
                    "type": "string",
                    "example": "manual"
                  },
                  "showCompletedTasks": {
                    "type": "boolean",
                    "example": true
                  }
                }
              }
            }
          }
        },
        "responses": {
          "200": { "$ref": "#/components/responses/TaskSettingsResponse" },
          "401": { "$ref": "#/components/responses/Unauthorized" }
        }
      }
    },
    "/user/settings/label": {
      "patch": {
        "tags": ["User"],
        "operationId": "updateLabelSettings",
        "summary": "Update label settings",
        "security": [{ "bearerAuth": [] }],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "required": [
                  "showLabelsOnCard",
                  "labelDisplay",
                  "maxLabelsShown"
                ],
                "properties": {
                  "showLabelsOnCard": {
                    "type": "boolean",
                    "example": true
                  },
                  "labelDisplay": {
                    "type": "string",
                    "example": "full"
                  },
                  "maxLabelsShown": {
                    "type": "string",
                    "example": "three"
                  }
                }
              }
            }
          }
        },
        "responses": {
          "200": { "$ref": "#/components/responses/LabelSettingsResponse" },
          "401": { "$ref": "#/components/responses/Unauthorized" }
        }
      }
    },
    "/user/settings/accessibility": {
      "patch": {
        "tags": ["User"],
        "operationId": "updateAccessibilitySettings",
        "summary": "Update accessibility settings",
        "security": [{ "bearerAuth": [] }],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "required": ["fontSize", "reducedMotion", "highContrast"],
                "properties": {
                  "fontSize": {
                    "type": "string",
                    "example": "small"
                  },
                  "reducedMotion": {
                    "type": "boolean",
                    "example": true
                  },
                  "highContrast": {
                    "type": "boolean",
                    "example": true
                  }
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "$ref": "#/components/responses/AccessibilitySettingsResponse"
          },
          "401": { "$ref": "#/components/responses/Unauthorized" }
        }
      }
    },
    "/board": {
      "get": {
        "tags": ["Board"],
        "operationId": "getAllBoards",
        "summary": "Get all boards",
        "security": [{ "bearerAuth": [] }],
        "responses": {
          "200": { "$ref": "#/components/responses/AllBoardsResponse" },
          "401": { "$ref": "#/components/responses/Unauthorized" }
        }
      },
      "post": {
        "tags": ["Board"],
        "operationId": "createBoard",
        "summary": "Create new board",
        "security": [{ "bearerAuth": [] }],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "properties": {
                  "title": {
                    "type": "string",
                    "minLength": 3,
                    "example": "My New Project"
                  },
                  "icon": { "$ref": "#/components/schemas/BoardIcon" },
                  "background": {
                    "$ref": "#/components/schemas/BoardBackgroundId"
                  }
                }
              }
            }
          }
        },
        "responses": {
          "201": { "$ref": "#/components/responses/BoardResponse" },
          "400": { "$ref": "#/components/responses/BoardBadRequest" },
          "401": { "$ref": "#/components/responses/Unauthorized" }
        }
      }
    },
    "/board/{boardId}": {
      "get": {
        "tags": ["Board"],
        "operationId": "getBoardById",
        "summary": "Get board by id",
        "parameters": [
          {
            "in": "path",
            "name": "boardId",
            "required": true,
            "schema": {
              "type": "string"
            }
          }
        ],
        "security": [{ "bearerAuth": [] }],
        "responses": {
          "200": { "$ref": "#/components/responses/BoardByIdResponse" },
          "401": { "$ref": "#/components/responses/Unauthorized" },
          "404": { "$ref": "#/components/responses/NotFound" }
        }
      },
      "patch": {
        "tags": ["Board"],
        "operationId": "updateBoard",
        "summary": "Update board by id",
        "parameters": [
          {
            "in": "path",
            "name": "boardId",
            "required": true,
            "schema": {
              "type": "string"
            }
          }
        ],
        "security": [{ "bearerAuth": [] }],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "properties": {
                  "title": {
                    "type": "string",
                    "minLength": 3,
                    "example": "Updated Project Office"
                  },
                  "icon": { "$ref": "#/components/schemas/BoardIcon" },
                  "background": {
                    "$ref": "#/components/schemas/BoardBackgroundId"
                  }
                }
              }
            }
          }
        },
        "responses": {
          "200": { "$ref": "#/components/responses/BoardResponse" },
          "400": { "$ref": "#/components/responses/BoardBadRequest" },
          "401": { "$ref": "#/components/responses/Unauthorized" },
          "404": { "$ref": "#/components/responses/NotFound" }
        }
      },
      "delete": {
        "tags": ["Board"],
        "operationId": "deleteBoard",
        "summary": "Delete board by id",
        "parameters": [
          {
            "in": "path",
            "name": "boardId",
            "required": true,
            "schema": {
              "type": "string"
            }
          }
        ],
        "security": [{ "bearerAuth": [] }],
        "responses": {
          "204": { "description": "The resource was deleted successfully." },
          "401": { "$ref": "#/components/responses/Unauthorized" },
          "404": { "$ref": "#/components/responses/NotFound" }
        }
      }
    },
    "/column/{boardId}": {
      "post": {
        "tags": ["Column"],
        "operationId": "createColumn",
        "summary": "Create new column",
