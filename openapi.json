          {
            "in": "path",
            "name": "columnId",
            "required": true,
            "schema": {
              "type": "string"
            }
          }
        ],
        "security": [{ "bearerAuth": [] }],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "properties": {
                  "title": {
                    "type": "string",
                    "minLength": 3,
                    "example": "Doing"
                  }
                }
              }
            }
          }
        },
        "responses": {
          "200": { "$ref": "#/components/responses/ColumnResponse" },
          "400": { "$ref": "#/components/responses/ColumnBadRequest" },
          "401": { "$ref": "#/components/responses/Unauthorized" },
          "404": { "$ref": "#/components/responses/NotFound" }
        }
      },
      "delete": {
        "tags": ["Column"],
        "operationId": "deleteColumn",
        "summary": "Delete column by id",
        "parameters": [
          {
            "in": "path",
            "name": "columnId",
            "required": true,
            "schema": {
              "type": "string"
            }
          }
        ],
        "security": [{ "bearerAuth": [] }],
        "responses": {
          "204": { "description": "The resource was deleted successfully." },
          "401": { "$ref": "#/components/responses/Unauthorized" },
          "404": { "$ref": "#/components/responses/NotFound" }
        }
      }
    },
    "/task/{columnId}": {
      "post": {
        "tags": ["Task"],
        "operationId": "createTask",
        "summary": "Create new task",
        "parameters": [
          {
            "in": "path",
            "name": "columnId",
            "required": true,
            "schema": {
              "type": "string"
            }
          }
        ],
        "security": [{ "bearerAuth": [] }],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "required": ["title", "priority"],
                "properties": {
                  "title": {
                    "type": "string",
                    "minLength": 3,
                    "example": "Publication of the project"
                  },
                  "description": {
                    "type": "string",
                    "minLength": 3,
                    "example": "Review the project materials: Familiarize yourself with the project's content, including text, images, and any supplementary materials."
                  },
                  "deadline": {
                    "type": "string",
                    "format": "date",
                    "example": "2025-10-15"
                  },
                  "priority": { "$ref": "#/components/schemas/TaskPriority" },
                  "labels": {
                    "type": "array",
                    "description": "Array of Label ids to attach to the task",
                    "items": { "type": "string" },
                    "example": ["6672fdccc07147fc7ae1bb93"]
                  }
                }
              }
            }
          }
        },
        "responses": {
          "201": { "$ref": "#/components/responses/TaskResponse" },
          "400": { "$ref": "#/components/responses/TaskBadRequest" },
          "401": { "$ref": "#/components/responses/Unauthorized" },
          "404": { "$ref": "#/components/responses/NotFound" }
        }
      }
    },
    "/task/{columnId}/order": {
      "patch": {
        "tags": ["Task"],
        "operationId": "updateTasksOrder",
        "summary": "Update tasks order",
        "parameters": [
          {
            "in": "path",
            "name": "columnId",
            "required": true,
            "schema": {
              "type": "string"
            }
          }
        ],
        "security": [{ "bearerAuth": [] }],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "required": ["ids"],
                "properties": {
                  "ids": {
                    "type": "array",
                    "items": {
                      "type": "string"
                    },
                    "example": [
                      "6672fdccc07147fc7ae1bb93",
                      "6743474be4006eca6c8122e7"
                    ]
                  }
                }
              }
            }
          }
        },
        "responses": {
          "200": { "$ref": "#/components/responses/UpdateTaskOrderResponse" },
          "400": { "$ref": "#/components/responses/UpdateOrderBadRequest" },
          "401": { "$ref": "#/components/responses/Unauthorized" },
          "404": { "$ref": "#/components/responses/NotFound" }
        }
      }
    },
    "/task/{taskId}": {
      "patch": {
        "tags": ["Task"],
        "operationId": "updateTask",
        "summary": "Update task by id",
        "parameters": [
          {
            "in": "path",
            "name": "taskId",
            "required": true,
            "schema": {
              "type": "string"
            }
          }
        ],
        "security": [{ "bearerAuth": [] }],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "properties": {
                  "title": {
                    "type": "string",
                    "minLength": 3,
                    "example": "Final Project Review"
                  },
                  "description": {
                    "type": ["string", "null"],
                    "minLength": 3,
                    "example": "Review and finalize all project documentation."
                  },
                  "deadline": {
                    "type": ["string", "null"],
                    "format": "date",
                    "example": "2025-11-01"
                  },
                  "priority": {
                    "allOf": [{ "$ref": "#/components/schemas/TaskPriority" }],
                    "example": "low"
                  },
                  "completed": {
                    "type": "boolean",
                    "example": true
                  },
                  "columnId": {
                    "type": "string",
                    "example": "6672fdccc07147fc7ae1bb93",
                    "description": "Id of the column to move the task to"
                  },
                  "labels": {
                    "type": "array",
                    "description": "Array of Label ids to attach to the task",
                    "items": { "type": "string" },
                    "example": ["6672fdccc07147fc7ae1bb93"]
                  }
                }
              }
            }
          }
        },
        "responses": {
          "200": { "$ref": "#/components/responses/TaskResponse" },
          "400": { "$ref": "#/components/responses/TaskBadRequest" },
          "401": { "$ref": "#/components/responses/Unauthorized" },
          "404": { "$ref": "#/components/responses/NotFound" }
        }
      },
      "delete": {
        "tags": ["Task"],
        "operationId": "deleteTask",
        "summary": "Delete task by id",
        "parameters": [
          {
            "in": "path",
            "name": "taskId",
            "required": true,
            "schema": {
              "type": "string"
            }
          }
        ],
        "security": [{ "bearerAuth": [] }],
        "responses": {
          "204": { "description": "The resource was deleted successfully." },
          "401": { "$ref": "#/components/responses/Unauthorized" },
          "404": { "$ref": "#/components/responses/NotFound" }
        }
      }
    },
    "/label": {
      "get": {
        "tags": ["Label"],
        "operationId": "getAllLabels",
        "summary": "Get all labels",
        "security": [{ "bearerAuth": [] }],
        "responses": {
          "200": { "$ref": "#/components/responses/AllLabelsResponse" },
          "401": { "$ref": "#/components/responses/Unauthorized" }
        }
      },
      "post": {
        "tags": ["Label"],
        "operationId": "createLabel",
        "summary": "Create new label",
        "security": [{ "bearerAuth": [] }],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "required": ["name", "color"],
                "properties": {
                  "name": {
                    "type": "string",
                    "minLength": 2,
                    "example": "Bug"
                  },
                  "color": { "$ref": "#/components/schemas/LabelColor" }
                }
              }
            }
          }
        },
        "responses": {
          "201": { "$ref": "#/components/responses/LabelResponse" },
          "400": { "$ref": "#/components/responses/LabelBadRequest" },
          "401": { "$ref": "#/components/responses/Unauthorized" }
        }
      }
    },
    "/label/{labelId}": {
      "patch": {
        "tags": ["Label"],
        "operationId": "updateLabel",
        "summary": "Update label by id",
        "parameters": [
          {
            "in": "path",
            "name": "labelId",
            "required": true,
            "schema": {
              "type": "string"
            }
          }
        ],
        "security": [{ "bearerAuth": [] }],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "properties": {
                  "name": {
                    "type": "string",
                    "minLength": 2,
                    "example": "Bug"
                  },
                  "color": { "$ref": "#/components/schemas/LabelColor" }
                }
              }
            }
          }
        },
        "responses": {
          "200": { "$ref": "#/components/responses/LabelResponse" },
          "400": { "$ref": "#/components/responses/LabelBadRequest" },
          "401": { "$ref": "#/components/responses/Unauthorized" },
          "404": { "$ref": "#/components/responses/NotFound" }
        }
      },
      "delete": {
        "tags": ["Label"],
        "operationId": "deleteLabel",
        "summary": "Delete label by id",
        "parameters": [
          {
            "in": "path",
            "name": "labelId",
            "required": true,
            "schema": {
              "type": "string"
            }
          }
        ],
        "security": [{ "bearerAuth": [] }],
        "responses": {
          "204": { "description": "The resource was deleted successfully." },
          "401": { "$ref": "#/components/responses/Unauthorized" },
          "404": { "$ref": "#/components/responses/NotFound" }
        }
      }
    }
  },
  "components": {
    "schemas": {
      "Board": {
        "type": "object",
        "required": [
          "id",
          "title",
          "icon",
          "background",
          "userId",
          "createdAt",
          "updatedAt"
        ],
        "properties": {
          "id": {
            "type": "string",
            "example": "6672f1d2f02c8b04130c718c"
          },
          "title": {
            "type": "string",
            "example": "Project office"
          },
          "icon": { "$ref": "#/components/schemas/BoardIcon" },
          "background": { "$ref": "#/components/schemas/BoardBackground" },
          "userId": {
            "type": "string",
            "example": "6671743db85c96453e04a684"
          },
          "columns": {
            "type": "array",
            "items": { "$ref": "#/components/schemas/Column" }
          },
          "createdAt": {
            "type": "string",
            "format": "date-time",
            "example": "2026-06-29T14:30:00.000Z"
          },
          "updatedAt": {
            "type": "string",
            "format": "date-time",
            "example": "2026-06-29T14:30:00.000Z"
          }
        }
      },
      "BoardBackground": {
        "type": "object",
        "required": ["identifier", "url"],
        "properties": {
          "identifier": { "$ref": "#/components/schemas/BoardBackgroundId" },
          "url": {
            "type": ["string", "null"],
            "format": "url",
            "example": "https://res.cloudinary.com/dmbnnewoy/image/upload/v1707099093/TaskPro/board_bg_images/desk/nfxep55xgvpq7xitemq1.jpg"
          }
        }
      },
      "BoardBackgroundId": {
        "type": "string",
        "enum": [
          "default",
          "flowers",
          "mountains-night",
          "sakura",
          "night-sky",
          "tropics",
          "light-sky",
          "sea-rocks",
          "blue-ball",
          "red-moon",
          "sea-boat",
          "air-balloons",
          "gorge",
          "sea-boat-2",
          "air-balloons-2",
          "northern-lights"
        ],
        "example": "flowers"
      },
      "BoardIcon": {
        "type": "string",
        "enum": [
          "sparkles",
          "layout",
          "kanban",
          "layers",
          "compass",
          "target",
          "sunrise",
          "orbit",
          "palette",
          "leaf"
        ],
        "example": "grid"
      },
