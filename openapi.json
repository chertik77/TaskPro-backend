            "type": "array",
            "items": { "$ref": "#/components/schemas/Label" }
          },
          "createdAt": {
            "type": "string",
            "format": "date-time",
            "example": "2026-06-29T14:30:00.000Z"
          },
          "updatedAt": {
            "type": "string",
            "format": "date-time",
            "example": "2026-06-29T14:30:00.000Z"
          }
